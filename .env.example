# Clerk — Dashboard > API Keys > Publishable key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Google Maps (rutas y mapa del campus)
EXPO_PUBLIC_GOOGLE_MAPS_APIKEY=

# Backend AXIS (rama integracion/backend corriendo con uvicorn en puerto 8000)
# Emulador Android: http://10.0.2.2:8000 — Dispositivo físico: http://<IP-de-tu-PC>:8000
EXPO_PUBLIC_API_URL=http://192.168.0.10:8000

# Cámara IP (app "IP Webcam" en Android) para el tracking en vivo
EXPO_PUBLIC_CAMERA_STREAM_URL=http://192.168.1.23:8080/video
